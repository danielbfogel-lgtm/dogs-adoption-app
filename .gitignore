# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# python
__pycache__/
*.pyc
.pytest_cache/
.ruff_cache/

# claude code (local-only settings; not shared)
.claude/settings.local.json
.claude/scheduled_tasks.lock

# stray scratch file
/Untitled

# supabase CLI local cache (project ref + pooler connection info; local machine state, not source)
/supabase/.temp/
